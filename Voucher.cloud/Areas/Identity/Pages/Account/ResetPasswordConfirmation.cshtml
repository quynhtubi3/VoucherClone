@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Voucher";;
}
<partial name="_header" />
<div class="row">
    <div class="col-md-8" style="background-color:#ffffff; border: 2px solid #ccc;">
        <section style="padding-left: 100px;padding-right: 100px;padding-top: 20px;">
            <h4 style="text-align:center; color:#000000; padding-bottom:10px;" class="noselect" data-i18n-key="LoginForm_Notice"></h4>
            <div style="text-align: center;color:#000000;">
                <p data-i18n-key="LoginForm_Var_ResetPassNotice1">                    
                </p>
                <p>
                    <a asp-page="./Login" data-i18n-key="LoginForm_Var_ResetPassNotice2"></a>.
                </p>
            </div>
                <partial name="_privacy" />                        
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
