@page
@model LoginWith2faModel
@{
    ViewData["Title"] = "Voucher";;
}
<partial name="_header" />
<div class="row">
    <div class="col-md-8" style="background-color:#ffffff; border: 2px solid #ccc;">
        <section style="padding-left: 100px;padding-right: 100px;padding-top: 20px;">
            <form id="account" method="post" onsubmit="return submitForm(this)">
                <input asp-for="RememberMe" type="hidden" />
                <h4 style="text-align:center; color:#000000; padding-bottom:10px;" class="noselect" data-i18n-key="LoginForm_Var_2FA_Authentication"></h4>

                <div class="form-group form-login-group">
                    <i class="fa fa-key prefix white-text"></i>
                    <input asp-for="Input.TwoFactorCode" class="form-control login-textbox" placeholder="Mã xác thực" placeholder-i18n-key="LoginForm_Var_2FA" />
                </div>
                <div class="form-group" style="display: flex; justify-content: space-between;">
                    <div class="checkbox noselect">
                        <div asp-for="Input.RememberMachine" style="color: #000000;">
                            <input asp-for="Input.RememberMachine" />
                            <label asp-for="Input.RememberMachine" style="color: #000000;" data-i18n-key="LoginForm_Var_RememberMachine"></label>
                        </div>
                    </div>
                </div>
                <div id="validate-session" class="text-danger">
                    <ul>
                        @foreach (var error in ViewData.ModelState.Where(s => s.Value.Errors.Count != 0).SelectMany(s => s.Value.Errors))
                        {
                            <li data-i18n-key="@error.ErrorMessage"></li>
                        }
                    </ul>
                </div>
                <div class="form-group" style="display: flex; justify-content: center;">
                    <button type="submit" class="btn" style="width:150px;border-radius: 20px;background-color:#1f6485;color:#ffffff;" data-i18n-key="LoginForm_Button_Login"></button>
                </div>
                <partial name="_privacy" />
            </form>
        </section>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


